#!/bin/bash

# Launch or focus on a given TUI identified by the passed in as the command.
# Use by commands like hyprland-launch-wifi so that there is only one wifi configuration screen open.

APP_ID="me.lovelett.hyprland.$(basename "$1")"
LAUNCH_COMMAND="hyprland-launch-tui $@"

exec hyprland-launch-or-focus "$APP_ID" "$LAUNCH_COMMAND"
